<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lapor Sampah UTS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-5">
        <h1 class="text-center mb-4">🗑️ Sistem Lapor Sampah Liar</h1>
        
        <div class="card shadow-sm mb-5">
            <div class="card-body">
                <h5 class="card-title">Buat Laporan Baru</h5>
                <form action="/lapor" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Nama Pelapor</label>
                        <input type="text" name="nama_pelapor" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Lokasi Sampah</label>
                        <input type="text" name="lokasi_sampah" class="form-control" placeholder="Contoh: Jl. Kenangan No. 4" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Deskripsi</label>
                        <textarea name="deskripsi" class="form-control" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Kirim Laporan!</button>
                </form>
            </div>
        </div>

        <h3 class="mb-3">Daftar Laporan Terbaru</h3>
        <div class="table-responsive">
            <table class="table table-striped table-hover bg-white shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Nama</th>
                        <th>Lokasi</th>
                        <th>Deskripsi</th>
                        <th>Status</th>
                        <th>Waktu</th>
                    </tr>
                </thead>
                <tbody>
                    <% laporan.forEach(item => { %>
                    <tr>
                        <td><%= item.nama_pelapor %></td>
                        <td><%= item.lokasi_sampah %></td>
                        <td><%= item.deskripsi %></td>
                        <td><span class="badge bg-warning text-dark"><%= item.status %></span></td>
                        <td><%= item.created_at.toLocaleString() %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>